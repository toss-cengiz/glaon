# apps/cloud — local dev secrets template. Copy to `.env` and fill in.
# Production / staging secrets land via `wrangler secret put` per ADR 0022;
# this file is for `wrangler dev --local` only.

# Sentry (optional in dev, required in prod). Without a DSN the cloud worker
# logs errors to console and skips Sentry calls — useful for offline dev.
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=

# Future secrets land here as the cloud features stack up:
# - CLERK_SECRET_KEY    (#344 home registry / Clerk JWT verify)
# - PAIR_BCRYPT_SECRET  (#346 pairing endpoint, ADR 0021)
# - DATABASE_URL        (B2 home registry, after #344)
