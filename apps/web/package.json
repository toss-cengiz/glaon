{
  "name": "@glaon/web",
  "version": "0.0.0",
  "dependencies": {
    "@clerk/clerk-react": "^5.61.6",
    "@glaon/core": "workspace:*",
    "@glaon/ui": "workspace:*",
    "@sentry/browser": "^10.49.0",
    "i18next": "^23.16.8",
    "i18next-browser-languagedetector": "^8.0.2",
    "i18next-icu": "^2.3.0",
    "intl-messageformat": "^10.7.13",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^15.3.0"
  },
  "devDependencies": {
    "@glaon/config": "workspace:*",
    "@sentry/vite-plugin": "^5.2.0",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^25.0.1",
    "tailwindcss": "^4",
    "typescript": "^5.7.2",
    "vite": "8.0.11",
    "vitest": "^4.1.5"
  },
  "private": true,
  "scripts": {
    "build": "pnpm --filter @glaon/ui build:tokens && tsc -b && vite build",
    "build:addon": "pnpm --filter @glaon/ui build:tokens && tsc -b && vite build --base=./ --mode development",
    "clean": "rm -rf dist .turbo coverage",
    "dev": "pnpm --filter @glaon/ui build:tokens && vite",
    "lint": "eslint .",
    "preview": "vite preview",
    "size": "size-limit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "type": "module"
}
