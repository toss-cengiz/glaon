# MongoDB connection string. The docker-compose dev setup defaults to
# `mongodb://glaon:glaon@localhost:27017/?authSource=admin`. Production
# values come from the deploy pipeline (#422).
MONGODB_URI=mongodb://glaon:glaon@localhost:27017/?authSource=admin

# Database name. The compose setup creates this on first startup.
MONGODB_DB=glaon

# HTTP port. Compose maps host:8080 → container:8080.
PORT=8080

# Log level — one of: debug, info, warn, error.
LOG_LEVEL=info

# Session JWT signing key (P2-D, #418). Must be at least 32 bytes
# (256 bits). Generate locally with: openssl rand -hex 32
# Production deploy injects this from the deploy pipeline (#422).
SESSION_JWT_SECRET=

# Session JWT lifetime in seconds. Default 3600 (1h). Refresh path lets
# clients re-mint before expiry.
SESSION_TTL_SECONDS=3600

# Comma-separated allowlist of web origins that should receive a
# Set-Cookie header for the session JWT. Mobile clients use the
# Authorization header instead and don't appear in this list.
# Example: WEB_ORIGINS=https://app.glaon.com,http://localhost:5173
WEB_ORIGINS=

# Build metadata. The deploy pipeline injects these; locally they
# default to placeholders.
GLAON_API_VERSION=0.0.0-dev
GLAON_API_COMMIT=
GLAON_API_BUILT_AT=
