# Glaon root-level developer env. Per-developer values; commit only the
# template (`.env.example`), never the populated `.env`.
#
# How to use:
#   1. Copy: `cp .env.example .env`
#   2. Fill in the values below.
#   3. Source the file (or add the exports to your shell rc) so processes
#      like Claude Code can read them — e.g. add to `~/.zshrc`:
#        set -a; source /absolute/path/to/glaon/.env; set +a
#
# `.env` is gitignored. App-specific envs live in `apps/web/.env.example`
# and `apps/mobile/.env.example`.

# Untitled UI Pro API key. Required by the `untitledui` MCP server entry
# in `.mcp.json` — header value is `Bearer ${UNTITLED_TOKEN}`. Acquire
# from your Untitled UI Pro dashboard.
UNTITLED_TOKEN=

# Local Home Assistant dev fixture — see docs/home-assistant-dev.md.
# Run `pnpm ha:up` to start the docker compose service. Used by ad-hoc
# scripts and dev tools; per-app envs (apps/web/.env.example,
# apps/mobile/.env.example) carry their own VITE_/EXPO_PUBLIC_ variants.
HA_BASE_URL=http://localhost:8123
