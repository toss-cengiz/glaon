{
  "name": "@glaon/ui",
  "version": "0.0.0",
  "devDependencies": {
    "@glaon/config": "workspace:*",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-designs": "^11.1.3",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-native-web-vite": "^10.3.5",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "6.0.1",
    "@vitest/browser": "^4",
    "@vitest/browser-playwright": "^4",
    "@vitest/coverage-v8": "^4.1.5",
    "chromatic": "^16.3.0",
    "glob": "^13.0.6",
    "jsdom": "^25.0.1",
    "playwright": "^1.59.1",
    "react": "^19.2.5",
    "react-docgen-typescript": "^2.4.0",
    "react-dom": "^19.2.5",
    "react-native": "^0.85.2",
    "react-native-web": "^0.21.2",
    "storybook": "^10.3.5",
    "storybook-dark-mode": "^5.0.0",
    "style-dictionary": "^5.4.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4",
    "tailwindcss-animate": "^1.0.7",
    "tailwindcss-react-aria-components": "^2.1.0",
    "typescript": "^5.7.2",
    "vite": "8.0.9",
    "vitest": "^4.1.5"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "main": "./src/index.ts",
  "peerDependencies": {
    "react": ">=19"
  },
  "private": true,
  "scripts": {
    "build": "tsc -b",
    "build-storybook": "pnpm build:tokens && storybook build",
    "build:tokens": "style-dictionary build --config style-dictionary.config.js",
    "chromatic": "chromatic",
    "clean": "rm -rf dist .turbo storybook-static coverage",
    "lint": "eslint .",
    "package-contract": "publint && attw --pack . --ignore-rules cjs-resolves-to-esm internal-resolution-error no-resolution",
    "storybook": "pnpm build:tokens && storybook dev -p 6006 --no-open",
    "test": "vitest run --project=unit",
    "test:coverage": "vitest run --project=unit --coverage",
    "test:stories": "pnpm build:tokens && vitest run --project=storybook",
    "type-check": "tsc --noEmit"
  },
  "type": "module",
  "types": "./src/index.ts",
  "dependencies": {
    "@internationalized/date": "^3.12.0",
    "@react-stately/utils": "^3.11.0",
    "@react-types/shared": "^3.34.0",
    "@untitledui/icons": "^0.0.22",
    "flag-icons": "^7.5.0",
    "react-aria": "^3.48.0",
    "react-aria-components": "^1.17.0",
    "react-stately": "^3.46.0"
  }
}
