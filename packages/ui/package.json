    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^2.1.8",
    "chromatic": "^16.3.0",
    "jsdom": "^25.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-native": "^0.85.2",
    "react-native-web": "^0.21.2",
