{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "tools/figma-plugin/code.js",
    "tools/figma-plugin/scripts/**",
    ".lighthouserc.cjs",
    ".lighthouserc.mobile.cjs"
  ],
  "ignoreBinaries": ["eslint"],
  "workspaces": {
    ".": {
      "entry": ["commitlint.config.mjs", "eslint.config.mjs"]
    },
    "apps/web": {
      "entry": [
        "src/main.tsx",
        "src/test/setup.ts",
        "src/**/*.test.{ts,tsx}",
        "vite.config.ts",
        "vitest.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "vite": false,
      "vitest": false,
      "ignoreDependencies": ["@glaon/ui", "@glaon/config"]
    },
    "apps/cloud": {
      "entry": ["src/**/*.test.ts", "wrangler.toml"],
      "project": ["src/**/*.ts"],
      "ignoreDependencies": ["@glaon/config"]
    },
    "apps/web-e2e": {
      "entry": ["tests/**/*.spec.ts"],
      "project": ["**/*.ts"],
      "ignoreDependencies": ["@glaon/config"]
    },
    "apps/mobile": {
      "entry": ["App.tsx"],
      "project": ["**/*.{ts,tsx}"],
      "ignoreDependencies": [
        "@glaon/ui",
        "@glaon/config",
        "@babel/core",
        "expo-crypto",
        "expo-updates",
        "expo-system-ui"
      ],
      "ignoreUnresolved": ["babel-preset-expo"]
    },
    "packages/core": {
      "project": ["src/**/*.{ts,tsx}"],
      "ignoreDependencies": ["@glaon/config"]
    },
    "packages/ui": {
      "entry": ["src/**/*.stories.@(ts|tsx)"],
      "project": ["src/**/*.{ts,tsx}", ".storybook/**/*.{ts,tsx}"],
      "ignore": [
        "src/components/base/**",
        "src/components/application/breadcrumbs/**",
        "src/components/application/date-picker/**",
        "src/components/shared-assets/**",
        "src/components/marketing/**",
        "src/utils/is-react-component.ts"
      ],
      "ignoreDependencies": [
        "@glaon/config",
        "tailwindcss",
        "@tailwindcss/typography",
        "tailwindcss-animate",
        "tailwindcss-react-aria-components",
        "flag-icons"
      ]
    },
    "packages/config": {
      "project": ["**/*.{js,ts}"]
    }
  }
}
